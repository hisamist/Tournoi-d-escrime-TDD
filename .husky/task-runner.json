{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "Auto Format Staged Files",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [
            "format",
            "--include",
            "${staged}"
         ],
         "include": ["**/*.cs", "**\\*.cs"],
         "output": "Always"
      },
      {
         "name": "Re-stage Formatted Files",
         "group": "pre-commit",
         "command": "git",
         "args": [
            "add",
            "${staged}"
         ],
         "include": ["**/*.cs", "**\\*.cs"]
      }
   ]
}